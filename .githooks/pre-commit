#!/usr/bin/env bash
#
# Very strict pre-commit hook that validates formatting, linting, and tests.
# Prevent commits that would otherwise break the CI/CD pipeline!
#
echo "[==== RUNNING PRE-COMMIT GITHOCK ====]"

# --- 1. Go Formatting and Linting ---
echo "=> Running Go Format / Buf Format..."
make format
if [ $? -ne 0 ]; then
    echo "ERROR: Go code or protobufs failed to format!"
    exit 1
fi

echo "=> Running golangci-lint..."
make lint
if [ $? -ne 0 ]; then
    echo "ERROR: Backend code has linting errors (unused vars, unchecked errs, etc)!"
    exit 1
fi

# --- 2. Go Unit Tests ---
echo "=> Executing Go Backend Tests..."
make test
if [ $? -ne 0 ]; then
    echo "ERROR: Some Go unit tests are currently failing! Fix them before committing."
    exit 1
fi

# --- 3. Frontend React Evaluation ---
# We can dynamically CD into the frontend and securely execute npm scripts!
echo "=> Executing React Frontend Lints..."
make frontend-lint
if [ $? -ne 0 ]; then
    echo "ERROR: The Frontend React code contains ESLint errors/warnings!"
    exit 1
fi

echo "=> Executing React Unit Tests..."
make frontend-test
if [ $? -ne 0 ]; then
    echo "ERROR: The Frontend React tests failed!"
    exit 1
fi

echo "[==== PRE-COMMIT CHECKS PASSED ✅ ====]"
exit 0
